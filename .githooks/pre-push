#!/usr/bin/env bash
# pre-push hook — runs quality checks before pushing to remote
# Blocks the push if lint, typecheck, backend tests, or frontend E2E fail.
# Frontend E2E: builds the app first (avoids Next.js dev-lock conflict with a
# running dev server on port 3001), then starts via `npm start` on port 3099.
#
# Setup (run once after cloning):
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
BACKEND_DIR="$REPO_ROOT/backend"
FRONTEND_DIR="$REPO_ROOT/frontend"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "🔍 Running pre-push quality checks..."
echo ""

# ─────────────────────────────────────────
# Run backend and frontend checks in parallel
# ─────────────────────────────────────────

BACKEND_LOG=$(mktemp)
FRONTEND_LOG=$(mktemp)

(
  cd "$BACKEND_DIR"
  npm run lint --silent 2>&1 && \
  npm run typecheck --silent 2>&1 && \
  npm run test --silent 2>&1
) > "$BACKEND_LOG" 2>&1 &
BACKEND_PID=$!

(
  cd "$FRONTEND_DIR"
  npm run lint --silent 2>&1 && \
  npm run typecheck --silent 2>&1 && \
  E2E_BUILD=true npm run build --silent 2>&1 && \
  fuser -k 3099/tcp 2>/dev/null || true && \
  E2E_BUILD=true CI=true npx playwright test --project=chromium 2>&1
) > "$FRONTEND_LOG" 2>&1 &
FRONTEND_PID=$!

# ─────────────────────────────────────────
# Wait and report results
# ─────────────────────────────────────────

FAILED=0

if wait $BACKEND_PID; then
  echo -e "  ${GREEN}✓${NC} Backend  — lint, typecheck, unit tests"
else
  echo -e "  ${RED}✗${NC} Backend  — failed"
  echo ""
  cat "$BACKEND_LOG"
  FAILED=1
fi

if wait $FRONTEND_PID; then
  echo -e "  ${GREEN}✓${NC} Frontend — lint, typecheck, build, behavioral E2E"
else
  echo -e "  ${RED}✗${NC} Frontend — failed (lint / typecheck / build / E2E)"
  echo ""
  cat "$FRONTEND_LOG"
  FAILED=1
fi

rm -f "$BACKEND_LOG" "$FRONTEND_LOG"

echo ""

if [ $FAILED -ne 0 ]; then
  echo -e "${RED}Push bloqueado.${NC} Corrija os erros acima e tente novamente."
  echo -e "${YELLOW}Para pular (emergências):${NC} git push --no-verify"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ Tudo ok — push liberado.${NC}"
echo ""
exit 0
