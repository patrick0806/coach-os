# ─────────────────────────────────────────────────────────────────────────────
# Coach OS — Backup Environment Variables
# Copy this file to .env.backup and fill in the values.
# NEVER commit .env.backup to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=coachos
POSTGRES_USER=coachos
POSTGRES_PASSWORD=your_postgres_password

# Docker container name (default: coach-os-postgres-1)
POSTGRES_CONTAINER=coach-os-postgres-1

# ── S3 Backup Credentials (dedicated IAM user — NOT the app credentials) ─────
BACKUP_AWS_ACCESS_KEY_ID=YOUR_BACKUP_IAM_ACCESS_KEY
BACKUP_AWS_SECRET_ACCESS_KEY=YOUR_BACKUP_IAM_SECRET_KEY
BACKUP_AWS_REGION=us-east-1

BACKUP_S3_BUCKET=your-backup-bucket-name
BACKUP_S3_PREFIX=backups

# ── Retention ─────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=7

# ── Better Stack Logging ──────────────────────────────────────────────────────
# Source: coach-os-backup (ID: 2321227)
# Get this token from Better Stack > Logs > coach-os-backup > Settings
BACKUP_BETTERSTACK_TOKEN=nwto5Yxa8yV7KVuMRqKX1H4p
