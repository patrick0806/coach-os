# ─────────────────────────────────────────────────────────────────────────────
# Coach OS — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL
POSTGRES_DB=coachos
POSTGRES_USER=coachos
POSTGRES_PASSWORD=change_me_in_production

# ─────────────────────────────────────────
# Better Stack — Telemetry
# Source tokens from https://logs.betterstack.com
# ─────────────────────────────────────────

# Source: coach-os-backend
BETTERSTACK_BACKEND_TOKEN=your_token_here
BETTERSTACK_BACKEND_HOST=your_host_here

# Source: coach-os-frontend
BETTERSTACK_FRONTEND_TOKEN=your_token_here
BETTERSTACK_FRONTEND_HOST=your_host_here

# Source: coach-os-infra — traces + host metrics
BETTERSTACK_INFRA_TOKEN=your_token_here
BETTERSTACK_INFRA_HOST=your_host_here

# Application DSNs — error tracking (Sentry-compatible SDK)
BETTERSTACK_BACKEND_DSN=your_dsn_here
BETTERSTACK_FRONTEND_DSN=your_dsn_here

# ─────────────────────────────────────────
# Subdomain Routing
# ─────────────────────────────────────────

# Backend (.env): cookie domain for cross-subdomain sharing
# Leave empty for localhost dev. Set to .coachos.com.br in production.
# COOKIE_DOMAIN=.coachos.com.br

# Frontend (.env.local): same value as COOKIE_DOMAIN
# NEXT_PUBLIC_COOKIE_DOMAIN=.coachos.com.br

# Frontend (.env.local): base domain for subdomain detection in proxy.ts
# Default: coachos.com.br — no need to set in dev (proxy skips subdomain detection on localhost)
# NEXT_PUBLIC_BASE_DOMAIN=coachos.com.br

# ─────────────────────────────────────────
# Frontend — NEXT_PUBLIC_* (build-time)
# ─────────────────────────────────────────
# These are inlined by Next.js at build time. In CI/CD they must be
# passed as GitHub Secrets and forwarded as Docker build-args.
#
# NEXT_PUBLIC_API_URL=https://api.coachos.com.br/api/v1
# NEXT_PUBLIC_APP_URL=https://app.coachos.com.br
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# NEXT_PUBLIC_SHOW_TUTORIAL=true
